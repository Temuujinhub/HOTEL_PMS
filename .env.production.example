# =============================================================================
# Cloud PMS — PRODUCTION environment reference
#
# You normally DON'T create this by hand: on the first deploy the
# deploy/remote-deploy.sh script generates /opt/cloud-pms/.env with strong
# random secrets and reuses it on every later deploy.
#
# This file documents every variable in case you want to manage the .env
# yourself (e.g. to plug in real provider keys or a custom domain).
# =============================================================================

# --- Database (internal only — not exposed to the internet) ---
POSTGRES_USER=pms
POSTGRES_PASSWORD=replace_with_a_long_random_string
POSTGRES_DB=cloudpms

# --- Auth secrets (MUST be long random strings; min 16 chars) ---
JWT_ACCESS_SECRET=replace_with_64_hex_chars
JWT_REFRESH_SECRET=replace_with_64_hex_chars
JWT_ACCESS_TTL=900            # access token lifetime (seconds) = 15 min
JWT_REFRESH_TTL=604800        # refresh token lifetime (seconds) = 7 days

# AES-256-GCM key for PII at rest (any string >= 16 chars; hashed to 32 bytes)
ENCRYPTION_KEY=replace_with_a_random_string

# --- Public URL / CORS ---
# Bare IP for now; switch to https://your-domain.com once DNS + TLS are set up.
PUBLIC_URL=http://168.144.41.111
NEXT_PUBLIC_API_URL=http://168.144.41.111
CORS_ORIGINS=http://168.144.41.111

# Set to "true" only when you want to (re)load the two demo tenants.
SEED_ON_START=false
