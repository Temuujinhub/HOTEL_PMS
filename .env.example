# =============================================================================
# Cloud PMS — Root environment (used by docker-compose)
# Copy to .env and adjust for your deployment.
# =============================================================================

# --- Postgres ---
POSTGRES_USER=pms
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=cloudpms
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- API service ---
API_PORT=4000
NODE_ENV=production

# Connection string the API uses to reach Postgres (inside docker network)
DATABASE_URL=postgresql://pms:change_me_in_production@postgres:5432/cloudpms?schema=public
REDIS_URL=redis://redis:6379

# Auth secrets — MUST be replaced with long random strings in production
JWT_ACCESS_SECRET=replace_with_a_long_random_string_access
JWT_REFRESH_SECRET=replace_with_a_long_random_string_refresh
JWT_ACCESS_TTL=900            # 15 minutes (seconds)
JWT_REFRESH_TTL=604800        # 7 days (seconds)

# CORS — comma separated list of allowed web origins
CORS_ORIGINS=http://localhost:3000

# --- Web service ---
WEB_PORT=3000
# URL the browser uses to reach the API (public)
NEXT_PUBLIC_API_URL=http://localhost:4000
