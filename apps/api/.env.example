# Cloud PMS API — local environment example. Copy to .env for local dev.
NODE_ENV=development
API_PORT=4000

# Postgres
DATABASE_URL=postgresql://pms:pms_dev_pw@localhost:5432/cloudpms?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT secrets (use long random strings in production)
JWT_ACCESS_SECRET=dev_access_secret_change_me_please_1234567890
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_please_1234567890
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Encryption key for PII at rest (>=16 chars; 32 recommended)
ENCRYPTION_KEY=dev_only_32_byte_encryption_key!!

# CORS (comma separated)
CORS_ORIGINS=http://localhost:3000
